DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/db_name

# Docker Compose helpers (optional)
# Dev stack
DB_PORT=5432
API_BIND_HOST=127.0.0.1
API_PORT=7090
POSTGRES_USER=onboarding
POSTGRES_PASSWORD=onboarding
POSTGRES_DB=onboarding_db
DATABASE_URL_DOCKER=postgresql+asyncpg://onboarding:onboarding@db:5432/onboarding_db

# Disposable test DB (`docker-compose.test.yaml`)
DB_TEST_PORT=5433
POSTGRES_TEST_USER=onboarding
POSTGRES_TEST_PASSWORD=onboarding
POSTGRES_TEST_DB=onboarding_test_db
DATABASE_TEST_URL=postgresql+asyncpg://onboarding:onboarding@localhost:5433/onboarding_test_db

# Application
APP_NAME=Onboarding Service
DEBUG=true
API_V1_PREFIX=/api/v1

# Auth / JWT (Keycloak)
# - `AUTH_TENANT_CLAIM` is the *JWT claim name/path* that contains the tenant identifier.
#   It supports dotted paths for nested claims.
#   Example: if your decoded JWT payload contains `"ovp_claims": {"tenant_id": "ovp"}`, set:
#   AUTH_TENANT_CLAIM=ovp_claims.tenant_id
#
#   For multi-realm setups where each realm uses "<realm>_claims.tenant_id", you can use:
#   AUTH_TENANT_CLAIM=tenant_id,{realm}_claims.tenant_id
AUTH_ENABLED=true
AUTH_TENANT_CLAIM=tenant_id
AUTH_ALGORITHMS=RS256
AUTH_AUDIENCE=account
# Optional allow-list of JWT issuers (comma-separated). If empty, issuers are
# accepted when their base matches KEYCLOAK_TRUSTED_ISSUER_BASES (or the host
# of KEYCLOAK_ADMIN_BASE_URL / KEYCLOAK_BASE_URL).
AUTH_ISSUERS=

# JWKS (public keys) source (pick one)
# KEYCLOAK_JWKS_URL=https://keycloak.dev/realms/ovp/protocol/openid-connect/certs
# Optional: static JWKS sources. If empty, JWKS is resolved dynamically from the
# token issuer: <iss>/protocol/openid-connect/certs
KEYCLOAK_JWKS_URLS=
# Optional: trusted issuer bases (comma-separated). Recommended in production.
KEYCLOAK_TRUSTED_ISSUER_BASES=https://keycloak.dev
KEYCLOAK_JWKS_JSON={"keys":[...]}
JWKS_REFRESH_SECONDS=86400
JWKS_REQUIRED=true
# Optional headers for JWKS fetch (if Keycloak is behind an allowlist/proxy)
# JWKS_FETCH_HEADERS_JSON={"Authorization":"Bearer <token>"}
JWKS_FETCH_TIMEOUT_SECONDS=10

# Endpoint authorization (comma-separated roles)
# Example: TEMPLATES_REQUIRED_ROLES=maker
TEMPLATES_REQUIRED_ROLES=

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=onboarding-task-queue
TEMPORAL_ENABLED=true
TEMPORAL_REQUIRED=false

# Keycloak token proxy (US-204: Kong → this service → Keycloak)
# Used by:
#   POST /api/auth/login/{realm}
#   POST /api/auth/refresh/{realm}
KEYCLOAK_BASE_URL=
# Use either a single client for all realms:
KEYCLOAK_CLIENT_ID=test-client
KEYCLOAK_CLIENT_SECRET=
# Or per-realm clients:
# KEYCLOAK_CLIENTS_JSON={"ovp":{"client_id":"..."},"daf":{"client_id":"...","client_secret":"..."}}
# Or multiple clients per realm (select with ?client=mobile):
# KEYCLOAK_CLIENTS_JSON={"ovp":{"default":"mobile","clients":{"mobile":{"client_id":"..."},"web":{"client_id":"..."}}}}
# Optional allow-list of realms (comma-separated).
# If empty, the service validates realm existence by calling Keycloak discovery.
KEYCLOAK_REALMS=

# Keycloak provisioning (US-201). Only enable in trusted environments.
KEYCLOAK_PROVISIONING_ENABLED=false
KEYCLOAK_PROVISIONING_REQUIRED=false
# Optional: dedicated base URL for Admin API calls (can differ from KEYCLOAK_BASE_URL).
KEYCLOAK_ADMIN_BASE_URL=
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=oaas-provisioner
# Prefer service-account auth (client_credentials):
KEYCLOAK_ADMIN_CLIENT_SECRET=changeme
# Or fall back to admin username/password:
KEYCLOAK_ADMIN_USERNAME=
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_TENANT_CLIENT_ID=oaas-client
KEYCLOAK_TENANT_CLIENT_CONFIDENTIAL=true

# Optional internal guard: when set, tenant provisioning endpoints require:
#   X-Provisioning-Key: <value>
PLATFORM_PROVISIONING_API_KEY=

# AuthZ policy cache TTL (seconds)
AUTHZ_CACHE_TTL_SECONDS=30

# (Deprecated) Auto-creating Keycloak users on tenant creation.
# Use `POST /api/v1/tenants/{tenant_id}/users` instead.
KEYCLOAK_BOOTSTRAP_PASSWORD=
KEYCLOAK_BOOTSTRAP_USERS_JSON=
# Optional: used when you set emails yourself.
KEYCLOAK_BOOTSTRAP_EMAIL_DOMAIN=example.com
