DATABASE_URL=postgresql+asyncpg://onboarding:onboarding@localhost:5432/onboarding_db

# Docker Compose helpers (optional)
DB_PORT=5432
API_BIND_HOST=127.0.0.1
API_PORT=7090
POSTGRES_USER=onboarding
POSTGRES_PASSWORD=onboarding
POSTGRES_DB=onboarding_db
DATABASE_URL_DOCKER=postgresql+asyncpg://onboarding:onboarding@db:5432/onboarding_db

# Disposable test DB (`docker-compose.test.yaml`)
DB_TEST_PORT=5433
POSTGRES_TEST_USER=onboarding
POSTGRES_TEST_PASSWORD=onboarding
POSTGRES_TEST_DB=onboarding_test_db
DATABASE_TEST_URL=postgresql+asyncpg://onboarding:onboarding@localhost:5433/onboarding_test_db

# Application
APP_NAME=Onboarding & Verification Service
DEBUG=true
API_V1_PREFIX=/api/v1

# Auth / JWT (Keycloak)
AUTH_ENABLED=true
AUTH_TENANT_CLAIM=tenant_id,{realm}_claims.tenant_id
AUTH_ALGORITHMS=RS256
AUTH_AUDIENCE=account
AUTH_ISSUERS=
AUTH_EXCLUSIVE_ROLE_GROUPS=maker|checker

# JWKS
# Leave KEYCLOAK_JWKS_URLS empty when using dynamic issuer discovery.
KEYCLOAK_JWKS_URL=
KEYCLOAK_JWKS_URLS=
KEYCLOAK_JWKS_JSON=
KEYCLOAK_TRUSTED_ISSUER_BASES=http://127.0.0.1:8080
JWKS_REFRESH_SECONDS=86400
JWKS_REQUIRED=true
JWKS_FETCH_HEADERS_JSON=
JWKS_FETCH_TIMEOUT_SECONDS=10

# Endpoint authorization
TEMPLATES_REQUIRED_ROLES=

# Temporal
TEMPORAL_HOST=127.0.0.1:7233
TEMPORAL_HOST_DOCKER=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=onboarding-task-queue
TEMPORAL_ENABLED=true
TEMPORAL_REQUIRED=false

# Keycloak token proxy
KEYCLOAK_BASE_URL=http://127.0.0.1:8080
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
# Platform admin realm client mapping. Tenant realms use DB-stored client credentials after tenant initialization.
KEYCLOAK_CLIENTS_JSON={"master":{"client_id":"oaas-admin-ui","client_secret":"change-me-admin-ui-secret"}}
KEYCLOAK_REALMS=
KEYCLOAK_HTTP_HEADERS_JSON=
KEYCLOAK_HTTP_TIMEOUT_SECONDS=10
KEYCLOAK_REALM_DISCOVERY_TTL_SECONDS=3600

# Keycloak tenant initialization
KEYCLOAK_TENANT_INITIALIZATION_ENABLED=true
KEYCLOAK_TENANT_INITIALIZATION_REQUIRED=true
KEYCLOAK_ADMIN_BASE_URL=http://127.0.0.1:8080
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=oaas-provisioner
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me-provisioner-secret
KEYCLOAK_ADMIN_USERNAME=
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_TENANT_CLIENT_ID=oaas-client
KEYCLOAK_TENANT_CLIENT_CONFIDENTIAL=true
KEYCLOAK_BOOTSTRAP_PASSWORD=ChangeMe123!
KEYCLOAK_BOOTSTRAP_USERS_JSON=[{"username":"{realm}_tenant_admin","roles":["tenant_admin"],"first_name":"Tenant","last_name":"Admin"},{"username":"{realm}_maker","roles":["maker"]},{"username":"{realm}_checker","roles":["checker"]}]
KEYCLOAK_BOOTSTRAP_EMAIL_DOMAIN=example.com

# Optional shared secret for tenant initialization routes.
# Accepted header:
#   X-Initialization-Key: <value>
PLATFORM_INITIALIZATION_API_KEY=

# AuthZ policy cache TTL (seconds)
AUTHZ_CACHE_TTL_SECONDS=30

# User management integration
USER_MANAGEMENT_SERVICE_ENABLED=false
USER_MANAGEMENT_SERVICE_URL=
USER_MANAGEMENT_USER_PATH=users
USER_MANAGEMENT_TIMEOUT_SECONDS=10
