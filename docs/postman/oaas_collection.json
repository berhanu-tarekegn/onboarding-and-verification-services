{
  "info": {
    "_postman_id": "11111111-1111-1111-1111-111111111111",
    "name": "OAAS API (Auth + AuthZ + Tenant)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:7090"
    },
    {
      "key": "realm",
      "value": "demo"
    },
    {
      "key": "client",
      "value": "mobile"
    },
    {
      "key": "tenant",
      "value": "demo"
    },
    {
      "key": "username",
      "value": "demo_super_admin"
    },
    {
      "key": "password",
      "value": "test123"
    },
    {
      "key": "initialization_key",
      "value": ""
    },
    {
      "key": "product_id",
      "value": ""
    },
    {
      "key": "submission_id",
      "value": ""
    },
    {
      "key": "tenant_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/login/{{realm}}?client={{client}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}\n"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login ok', function () { pm.response.to.have.status(200); });",
                  "const j = pm.response.json();",
                  "pm.environment.set('access_token', j.access_token || '');",
                  "pm.environment.set('refresh_token', j.refresh_token || '');",
                  "pm.environment.set('token_type', j.token_type || 'Bearer');",
                  "pm.environment.set('expires_in', String(j.expires_in || ''));"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/refresh/{{realm}}?client={{client}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}\n"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('refresh ok', function () { pm.response.to.have.status(200); });",
                  "const j = pm.response.json();",
                  "pm.environment.set('access_token', j.access_token || '');",
                  "pm.environment.set('refresh_token', j.refresh_token || pm.environment.get('refresh_token') || '');",
                  "pm.environment.set('token_type', j.token_type || 'Bearer');",
                  "pm.environment.set('expires_in', String(j.expires_in || ''));"
                ]
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "AuthZ (Policy)",
      "item": [
        {
          "name": "Get Global Policy",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Initialization-Key",
                "value": "{{initialization_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/authz/policy"
          }
        },
        {
          "name": "Update Global Policy (merge example)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Initialization-Key",
                "value": "{{initialization_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/authz/policy",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policy\": {\n    \"mode\": \"merge\",\n    \"roles\": {\n      \"platform_admin\": [\n        \"products.read\",\n        \"products.create\",\n        \"products.update\",\n        \"products.delete\"\n      ]\n    },\n    \"columns\": {\n      \"maker\": {\n        \"submissions.read\": {\"deny\": [\"review_notes\",\"reviewed_by\",\"reviewed_at\"]},\n        \"submissions.update\": {\"allow\": [\"form_data\"]}\n      }\n    }\n  }\n}\n"
            }
          }
        },
        {
          "name": "Get Realm Policy (unlinked)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Initialization-Key",
                "value": "{{initialization_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/authz/realm-policy/{{realm}}"
          }
        },
        {
          "name": "Upsert Realm Policy (unlinked; merge example)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Initialization-Key",
                "value": "{{initialization_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/authz/realm-policy/{{realm}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policy\": {\n    \"mode\": \"merge\",\n    \"roles\": {\n      \"platform_admin\": [\"products.read\",\"products.create\",\"products.update\",\"products.delete\"],\n      \"maker\": [\"submissions.create\",\"submissions.read\",\"submissions.update\",\"submissions.submit\",\"submissions.comment\"],\n      \"checker\": [\"submissions.read_all\",\"submissions.transition\",\"submissions.comment\"]\n    },\n    \"columns\": {\n      \"maker\": {\n        \"submissions.read\": {\"deny\": [\"review_notes\",\"reviewed_by\",\"reviewed_at\"]},\n        \"submissions.update\": {\"allow\": [\"form_data\"]}\n      }\n    }\n  }\n}\n"
            }
          }
        },
        {
          "name": "Get Tenant Policy (by realm; tenant-linked)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Initialization-Key",
                "value": "{{initialization_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/authz/policy/{{realm}}"
          }
        },
        {
          "name": "Upsert Tenant Policy (by realm; tenant-linked)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Initialization-Key",
                "value": "{{initialization_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/authz/policy/{{realm}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policy\": {\n    \"mode\": \"merge\",\n    \"roles\": {\n      \"platform_admin\": [\"products.read\"]\n    }\n  }\n}\n"
            }
          }
        }
      ]
    },
    {
      "name": "Tenants (Admin)",
      "item": [
        {
          "name": "List Tenants",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/tenants"
          }
        },
        {
          "name": "Create Tenant",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Initialization-Key",
                "value": "{{initialization_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/tenants",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Platform\",\n  \"tenant_key\": \"{{tenant}}\"\n}\n"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('create tenant ok', function () { pm.expect([200, 201, 409]).to.include(pm.response.code); });",
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  if (j && j.id) pm.environment.set('tenant_id', j.id);",
                  "}",
                  "if (pm.response.code === 409) {",
                  "  const j = pm.response.json();",
                  "  const tid = (j && j.error && j.error.details && j.error.details.tenant_id) ? j.error.details.tenant_id : '';",
                  "  if (tid) pm.environment.set('tenant_id', tid);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Tenant User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Initialization-Key",
                "value": "{{initialization_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/tenants/{{tenant_id}}/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"national_id\": \"ET-0000000000\",\n  \"username\": \"{{tenant}}_maker\",\n  \"password\": \"test123\",\n  \"roles\": [\"maker\"],\n  \"first_name\": \"Maker\",\n  \"last_name\": \"User\",\n  \"email\": \"{{tenant}}_maker@example.com\",\n  \"phone_number\": \"+251900000000\",\n  \"address\": \"Addis Ababa\"\n}\n"
            }
          }
        },
        {
          "name": "Create My Tenant User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Initialization-Key",
                "value": "{{initialization_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/tenants/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"national_id\": \"1234567890123416\",\n  \"username\": \"{{realm}}_maker\",\n  \"password\": \"test123\",\n  \"roles\": [\"maker\"],\n  \"first_name\": \"Maker\",\n  \"last_name\": \"User\",\n  \"email\": \"maker@example.com\",\n  \"phone_number\": \"+251900020000\",\n  \"address\": \"Addis Ababa\"\n}\n"
            }
          }
        }
      ]
    },
    {
      "name": "Products (Tenant)",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Tenant-ID",
                "value": "{{tenant}}"
              }
            ],
            "url": "{{base_url}}/api/v1/products"
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{tenant}}"
              }
            ],
            "url": "{{base_url}}/api/v1/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"P1\",\n  \"description\": \"demo\",\n  \"product_code\": \"p1\"\n}\n"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('create product ok', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                  "const j = pm.response.json();",
                  "if (j && j.id) pm.environment.set('product_id', j.id);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Submissions (Tenant)",
      "item": [
        {
          "name": "Create Submission (Draft)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{tenant}}"
              }
            ],
            "url": "{{base_url}}/api/v1/submissions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"template_id\": \"00000000-0000-0000-0000-000000000000\",\n  \"form_data\": {\"field\": \"value\"}\n}\n"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('create submission ok', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                  "const j = pm.response.json();",
                  "if (j && j.id) pm.environment.set('submission_id', j.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "List Submissions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Tenant-ID",
                "value": "{{tenant}}"
              }
            ],
            "url": "{{base_url}}/api/v1/submissions"
          }
        },
        {
          "name": "Submit Submission",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Tenant-ID",
                "value": "{{tenant}}"
              }
            ],
            "url": "{{base_url}}/api/v1/submissions/{{submission_id}}/submit?validate=false"
          }
        },
        {
          "name": "Transition Submission (Approve example)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{tenant}}"
              }
            ],
            "url": "{{base_url}}/api/v1/submissions/{{submission_id}}/transition",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"to_status\": \"APPROVED\",\n  \"reason\": \"Approved via Postman\",\n  \"review_notes\": \"Looks good\"\n}\n"
            }
          }
        }
      ]
    }
  ]
}
